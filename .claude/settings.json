{
  "enabledPlugins": {
    "claude-code-harness@claude-code-harness-marketplace": true
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(ls*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(tailscale up*)",
      "Bash(tailscale status*)",
      "Bash(just *)",
      "mcp__kubectl__*",
      "mcp__argocd__*",
      "mcp__proxmox__*",
      "mcp__tailscale__*"
    ]
  }
}
